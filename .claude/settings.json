{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\\.(ts|tsx|css|json)$' || true); if [ -n \"$files\" ]; then echo \"$files\" | xargs npx prettier --write && echo \"$files\" | xargs git add; fi",
            "statusMessage": "Formatting staged files with Prettier..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/code-map-sync-hook.mjs\" 2>/dev/null || true",
            "statusMessage": "Checking CODE_MAP sync..."
          }
        ]
      }
    ]
  }
}
