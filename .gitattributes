* text=auto

# Force LF for source and config files (prevents CRLF warnings on Windows)
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.env* text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
