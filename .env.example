# WorkTrack Pro — single env template for local dev and Netlify
# Copy to .env.local for local dev. For Netlify, set variables in Site settings -> Environment variables.

# Supabase (required for app)
# Get these from: Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_from_supabase_dashboard

# WorkTrackAccounting module (build-time gate).
# Leave false/unset in production until the module graduates. Set to true in
# .env.local to develop it locally (reach it at /app/accounting/*). When false the
# accounting routes are not registered and the module is excluded from the build.
# Also requires the `accounting` schema to be added to Supabase "Exposed schemas"
# (Project Settings -> API) before the browser client can read/write its tables.
VITE_ACCOUNTING_ENABLED=false

# WorkTrackAccounting — TAX-SYNC scheduled function (SERVER-side gate, default OFF).
# Hard-gates the quarterly tax-table auto-refresh Netlify function
# (netlify/functions/tax-table-refresh.mjs, cron "0 6 1 1,4,7,10 *", plus the admin
# "check now" at POST /api/tax-table-refresh). A frontend build flag CANNOT gate a
# scheduled function, so THIS server env var is the isolation guarantee for the
# auto-refresh engine. When unset / false / 0 / off / no, the function exits
# IMMEDIATELY with NO external fetch and NO database write (it returns a clean
# "disabled" message to the UI). Set to true/1/yes/on ONLY after the module
# graduates AND a human has VERIFIED each source parser against the live CDTFA/EDD
# file format (see netlify/functions/lib/taxTableParsers.mjs "VERIFY" banners).
# This is a Netlify FUNCTION env var (Site settings -> Environment variables) — it
# is NOT a VITE_ build var and is never exposed to the browser. The function
# authenticates to Supabase with SUPABASE_SERVICE_ROLE_KEY (set below for the other
# functions) and ALWAYS stays within the accounting.* schema: it only writes
# append-only snapshots + "open" drift alerts and NEVER mutates stored tax rates
# (changing a rate is the explicit, admin-confirmed Apply action in the UI).
ACCOUNTING_TAX_SYNC_ENABLED=false

# WorkTrackAccounting — PHASE E (E5) SECURITY HARDENING (SERVER-side gate, default OFF).
# HELD / HIGH-RISK / UNVERIFIED — NOT FOR FILING. Requires a SECURITY review before enabling.
# Hard-gates the Netlify rate-limiting + input-hardening helpers
# (netlify/functions/lib/securityHardening.mjs) that are wired into submit-proposal,
# boards-for-addon, create-card-from-email and the tax-table-refresh "check now" trigger.
# When unset / false / 0 / off / no (the DEFAULT), EVERY helper is a NO-OP: the limiter never
# blocks and the body-size cap never rejects — so these functions behave EXACTLY as before this
# phase. A frontend build flag cannot gate a server function, so THIS env var is the isolation
# guarantee for the hardening layer. Set to true/1/yes/on ONLY after a security review AND load
# testing (the in-memory limiter is per-warm-instance + best-effort; a production deployment
# should back it with a distributed store — see the securityHardening.mjs header LIMITATION note).
# This is a Netlify FUNCTION env var (Site settings -> Environment variables); it is NOT a VITE_
# build var and is never exposed to the browser.
ACCOUNTING_SECURITY_HARDENING_ENABLED=false

# Optional per-route rate limits the E5 limiter uses WHEN hardening is enabled (above). These
# mirror the seeded accounting.settings 'security_rate_limits' row (migration 033) and override
# the in-code defaults shown. Leave unset to use the defaults. Ignored entirely while
# ACCOUNTING_SECURITY_HARDENING_ENABLED is off.
# ACCOUNTING_RL_DEFAULT_PER_MINUTE=30          # fallback fixed-window limit for any hardened route
# ACCOUNTING_RL_TAX_REFRESH_PER_HOUR=12        # manual tax-table "check now" POST path
# ACCOUNTING_RL_SUBMIT_PROPOSAL_PER_HOUR=20    # public submit-proposal function (per client IP)
# ACCOUNTING_RL_ADDON_PER_MINUTE=60            # Gmail add-on helper endpoints (per client IP)
# ACCOUNTING_RL_MAX_BODY_BYTES=262144          # 256 KiB JSON body cap for input-hardening

# Trello API (optional, for importing attachments from Trello)
# Get these from: https://trello.com/app-key
# 1. Go to https://trello.com/power-ups/admin and create/select your Power-Up
# 2. In API Key tab, set "Allowed Origins" to include:
#    - http://localhost:3000 (for local dev)
#    - https://your-netlify-site.netlify.app (for production)
#    - Or use * for development (less secure, but easier)
# 3. Copy your API Key
# 4. Generate a token: https://trello.com/1/authorize?expiration=never&scope=read&response_type=token&name=WorkTrackPro&key=YOUR_API_KEY
#    (Replace YOUR_API_KEY with your actual key)
# 5. Paste ONLY the token value (no extra characters, URLs, or suffixes)
# For Netlify: Add these same variables in Site settings -> Environment variables
VITE_TRELLO_API_KEY=your_trello_api_key_here
VITE_TRELLO_TOKEN=your_trello_token_here

# Optional: base URL for API calls (leave unset in production so /api/* uses same origin).
# For local dev: set to your Netlify site URL (e.g. https://your-site.netlify.app) to test proposal submit against production, or run "netlify dev" and use the proxy.
# VITE_API_ORIGIN=

# Public customer proposal site (required for proposal intake + spam protection)
VITE_TURNSTILE_SITE_KEY=your_cloudflare_turnstile_site_key
TURNSTILE_SECRET_KEY=your_cloudflare_turnstile_secret_key

# Proposal intake backend (required on Netlify function)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
PROPOSAL_ADMIN_EMAIL=quotes@roughcutmfg.com
APP_PUBLIC_URL=https://roughcutmfg.com/app

# Email notifications (optional but recommended for customer/admin confirmations)
RESEND_API_KEY=re_cDziEtqS_BandC7ksAFiwLj2QQCLCrLgt
PROPOSAL_FROM_EMAIL_ADMIN=Rough Cut Manufacturing <quotes@roughcutmfg.com>
PROPOSAL_FROM_EMAIL_CUSTOMER=Rough Cut Manufacturing <general@roughcutmfg.com>
# Backward-compatible fallback (still supported by submit-proposal):
# PROPOSAL_FROM_EMAIL=Rough Cut Manufacturing <general@roughcutmfg.com>

